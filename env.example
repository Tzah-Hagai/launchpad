SLACK_BOT_TOKEN=xoxb-your-bot-token-from-oauth-install
SLACK_SIGNING_SECRET=your-signing-secret-from-basic-information
PORT=3000

# Vercel: add SLACK_BOT_TOKEN + SLACK_SIGNING_SECRET in Project → Settings → Environment Variables (all environments you deploy to).
#
# Slack app → Interactivity & Shortcuts → turn Interactivity ON → Request URL:
#   https://<your-project>.vercel.app/slack/interactive

# Optional: only for one-off manual posting via post-message.mjs (or pass channel as argv)
# Use #channel-name for public channels, or channel ID. Example: SLACK_CHANNEL=#project-alpha
SLACK_CHANNEL=#your-channel

LINK_MONDAY=https://monday.com/boards/.../pulses/...
LINK_DESIGN=https://figma.com/... or your spec URL
LINK_JIRA=https://your-domain.atlassian.net/...
